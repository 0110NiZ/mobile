<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:id="@+id/tvLocationPromptMessage"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/location_first_use_message"
        android:textColor="?android:attr/textColorPrimary"
        android:textSize="14sp" />

    <Button
        android:id="@+id/btnLocationAccept"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:layout_marginTop="14dp"
        android:backgroundTint="@color/ssf_primary_variant"
        android:textColor="@android:color/white"
        android:text="@string/location_first_use_accept" />

    <Button
        android:id="@+id/btnLocationAskEveryTime"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:layout_marginTop="10dp"
        android:backgroundTint="@color/ssf_primary"
        android:textColor="@android:color/white"
        android:text="@string/location_first_use_ask_every_time" />

    <Button
        android:id="@+id/btnLocationDeny"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:layout_marginTop="10dp"
        android:backgroundTint="@color/ssf_primary"
        android:textColor="@android:color/white"
        android:text="@string/location_first_use_decline" />

</LinearLayout>
