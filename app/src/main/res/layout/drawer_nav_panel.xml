<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="304dp"
    android:layout_height="match_parent"
    android:layout_gravity="start"
    android:background="?attr/colorSurface"
    android:fillViewport="true"
    android:scrollbars="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="28dp">

        <!-- Profile -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="?attr/colorPrimaryVariant"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingTop="28dp"
            android:paddingEnd="20dp"
            android:paddingBottom="22dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:alpha="0.85"
                android:text="@string/drawer_app_label"
                android:textColor="@color/white"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/tvDrawerUserName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="@string/guest_user"
                android:textColor="@color/white"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvDrawerRole"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/drawer_role_guest"
                android:textColor="#E6FFFFFF"
                android:textSize="13sp" />
        </LinearLayout>

        <TextView
            style="@style/Widget.SSF.DrawerSectionLabel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/drawer_section_nav" />

        <TextView
            android:id="@+id/drawerNavHome"
            style="@style/Widget.SSF.DrawerRow"
            android:text="@string/drawer_nav_home" />

        <TextView
            android:id="@+id/drawerNavFavorites"
            style="@style/Widget.SSF.DrawerRow"
            android:text="@string/favorites" />

        <TextView
            android:id="@+id/drawerNavCompare"
            style="@style/Widget.SSF.DrawerRow"
            android:text="@string/compare" />

        <TextView
            android:id="@+id/drawerNavAbout"
            style="@style/Widget.SSF.DrawerRow"
            android:text="@string/about" />

        <TextView
            style="@style/Widget.SSF.DrawerSectionLabel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/drawer_section_location" />

        <LinearLayout
            android:id="@+id/drawerRowUseMyLocation"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:minHeight="52dp"
            android:orientation="horizontal"
            android:paddingStart="18dp"
            android:paddingEnd="14dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/drawer_use_my_location"
                android:textColor="?android:attr/textColorPrimary"
                android:textSize="15sp" />

            <androidx.appcompat.widget.SwitchCompat
                android:id="@+id/switchDrawerLocation"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:showText="false" />
        </LinearLayout>

        <TextView
            android:id="@+id/drawerSetLocation"
            style="@style/Widget.SSF.DrawerRow"
            android:text="@string/drawer_set_location" />

        <TextView
            style="@style/Widget.SSF.DrawerSectionLabel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/drawer_section_sorting_display" />

        <TextView
            android:id="@+id/drawerSortBy"
            style="@style/Widget.SSF.DrawerRow"
            android:text="@string/drawer_sort_by" />

        <TextView
            android:id="@+id/drawerNearest5"
            style="@style/Widget.SSF.DrawerRow"
            android:text="@string/drawer_nearest_5_schools" />

        <TextView
            style="@style/Widget.SSF.DrawerSectionLabel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/drawer_section_settings" />

        <LinearLayout
            android:id="@+id/drawerRowDarkMode"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:minHeight="52dp"
            android:orientation="horizontal"
            android:paddingStart="18dp"
            android:paddingEnd="14dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/drawer_dark_mode"
                android:textColor="?android:attr/textColorPrimary"
                android:textSize="15sp" />

            <androidx.appcompat.widget.SwitchCompat
                android:id="@+id/switchDrawerDarkMode"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:showText="false" />
        </LinearLayout>

        <TextView
            android:id="@+id/drawerLanguage"
            style="@style/Widget.SSF.DrawerRow"
            android:text="@string/drawer_language" />

        <TextView
            style="@style/Widget.SSF.DrawerSectionLabel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/drawer_section_help" />

        <TextView
            android:id="@+id/drawerFaq"
            style="@style/Widget.SSF.DrawerRow"
            android:text="@string/drawer_faq" />

        <TextView
            android:id="@+id/drawerContact"
            style="@style/Widget.SSF.DrawerRow"
            android:text="@string/drawer_contact_support" />

        <TextView
            android:id="@+id/drawerPrivacy"
            style="@style/Widget.SSF.DrawerRow"
            android:text="@string/drawer_privacy" />

        <TextView
            style="@style/Widget.SSF.DrawerSectionLabel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/drawer_section_app_info" />

        <TextView
            android:id="@+id/tvDrawerVersion"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="18dp"
            android:paddingTop="12dp"
            android:paddingEnd="18dp"
            android:textColor="?android:attr/textColorSecondary"
            android:textSize="12sp" />
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
