<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingStart="14dp"
    android:paddingTop="10dp"
    android:paddingEnd="14dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/feedback_prompt"
        android:textColor="?android:attr/textColorPrimary"
        android:textSize="16sp"
        android:textStyle="bold" />

    <RatingBar
        android:id="@+id/ratingFeedback"
        style="?android:attr/ratingBarStyle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:isIndicator="false"
        android:numStars="5"
        android:rating="0"
        android:stepSize="1"
        android:clickable="true"
        android:focusable="true"
        android:progressTint="@color/feedback_star_selected"
        android:secondaryProgressTint="@color/rating_star_unselected" />

    <EditText
        android:id="@+id/etFeedbackComment"
        android:layout_width="match_parent"
        android:layout_height="120dp"
        android:layout_marginTop="12dp"
        android:background="@drawable/bg_text_field"
        android:gravity="top|start"
        android:hint="@string/feedback_comment_hint"
        android:inputType="textMultiLine"
        android:maxLines="6"
        android:padding="12dp"
        android:textColor="?android:attr/textColorPrimary"
        android:textColorHint="?android:attr/textColorHint" />

</LinearLayout>
