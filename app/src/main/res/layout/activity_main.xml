<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    tools:openDrawer="start">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/ssf_bg"
        android:orientation="vertical">

        <!-- Premium header (brand + menu) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_gradient_header"
            android:elevation="6dp"
            android:orientation="vertical"
            android:paddingLeft="10dp"
            android:paddingTop="14dp"
            android:paddingRight="18dp"
            android:paddingBottom="18dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <FrameLayout
                    android:layout_width="48dp"
                    android:layout_height="48dp">

                    <ImageButton
                        android:id="@+id/btnOpenDrawer"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:contentDescription="@string/drawer_open"
                        android:padding="12dp"
                        android:scaleType="centerInside"
                        android:src="@drawable/ic_menu_24"
                        app:tint="@color/white" />

                    <View
                        android:id="@+id/viewTopMenuNotificationDot"
                        android:layout_width="9dp"
                        android:layout_height="9dp"
                        android:layout_gravity="top|end"
                        android:layout_marginTop="10dp"
                        android:layout_marginEnd="10dp"
                        android:background="@drawable/bg_notification_dot"
                        android:visibility="gone" />
                </FrameLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/home_title"
                        android:textColor="@color/white"
                        android:textSize="22sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="@string/home_subtitle"
                        android:textColor="#EFFFFFFF"
                        android:textSize="13sp" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

    <!-- Content -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:paddingLeft="14dp"
        android:paddingTop="12dp"
        android:paddingRight="14dp"
        android:paddingBottom="14dp">

        <!-- Everything above the toggle bar is collapsible -->
        <LinearLayout
            android:id="@+id/layoutFilterContent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Search + filters in a single card -->
            <com.google.android.material.card.MaterialCardView
                style="@style/Widget.SSF.Card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardUseCompatPadding="true">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:startIconDrawable="@drawable/ic_search_24"
                        app:startIconTint="@color/ssf_primary_variant">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etSearch"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="@string/search_hint"
                            android:imeOptions="actionSearch"
                            android:inputType="text" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <Button
                        android:id="@+id/btnSortBy"
                        style="@style/Widget.SSF.Button.Secondary"
                        android:layout_width="match_parent"
                        android:layout_height="46dp"
                        android:layout_marginTop="10dp"
                        android:text="@string/search" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Actions: primary / secondary / subtle -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:id="@+id/btnFavorites"
                        android:layout_width="0dp"
                        android:layout_height="64dp"
                        android:layout_weight="1"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:paddingLeft="8dp"
                        android:paddingTop="4dp"
                        android:paddingRight="8dp"
                        android:paddingBottom="4dp">

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:contentDescription="@string/favorites"
                            android:src="@drawable/ic_star_outline_24"
                            android:tint="@color/ssf_primary_variant" />

                        <TextView
                            android:id="@+id/tvFavoritesLabel"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:gravity="center"
                            android:text="@string/favorites"
                            android:textColor="@color/ssf_primary_variant"
                            android:textSize="12sp" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/btnCompare"
                        android:layout_width="0dp"
                        android:layout_height="64dp"
                        android:layout_marginStart="10dp"
                        android:layout_weight="1"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:paddingLeft="8dp"
                        android:paddingTop="4dp"
                        android:paddingRight="8dp"
                        android:paddingBottom="4dp">

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:contentDescription="@string/compare"
                            android:src="@drawable/ic_compare_arrows_24"
                            android:tint="@color/ssf_primary_variant" />

                        <TextView
                            android:id="@+id/tvCompareLabel"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:gravity="center"
                            android:text="@string/compare"
                            android:textColor="@color/ssf_primary_variant"
                            android:textSize="12sp" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/btnSortByQuick"
                        android:layout_width="0dp"
                        android:layout_height="64dp"
                        android:layout_marginStart="10dp"
                        android:layout_weight="1"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:paddingLeft="8dp"
                        android:paddingTop="4dp"
                        android:paddingRight="8dp"
                        android:paddingBottom="4dp">

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:contentDescription="@string/drawer_sort_by"
                            android:src="@drawable/ic_sort_24"
                            android:tint="@color/ssf_primary_variant" />

                        <TextView
                            android:id="@+id/tvSortByLabel"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:gravity="center"
                            android:text="@string/drawer_sort_by"
                            android:textColor="@color/ssf_primary_variant"
                            android:textSize="12sp" />
                    </LinearLayout>
                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

        <!-- Collapsible toggle bar (placed BELOW Favorites/Compare/Search row) -->
        <LinearLayout
            android:id="@+id/layoutFilterHeader"
            android:layout_width="match_parent"
            android:layout_height="36dp"
            android:layout_marginBottom="6dp"
            android:gravity="center"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/ivFilterToggle"
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:padding="8dp"
                android:src="@drawable/ic_arrow_up_16"
                android:contentDescription="Toggle filters" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvFilterResultHint"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="6dp"
            android:textColor="@color/ssf_text_secondary"
            android:textSize="13sp"
            android:visibility="gone"
            tools:text="Found 56 results" />

        <!-- States + list -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <!-- Loading: centered and calmer -->
            <LinearLayout
                android:id="@+id/loadingView"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="16dp">

                <ProgressBar
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="Loading schools…"
                    android:textColor="@color/ssf_text_secondary"
                    android:textSize="13sp" />
            </LinearLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerSchools"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:clipToPadding="false"
                android:paddingEnd="22dp"
                android:paddingBottom="8dp"
                android:visibility="gone" />

            <com.example.smartschoolfinder.widget.SideBar
                android:id="@+id/sideBar"
                android:layout_width="22dp"
                android:layout_height="match_parent"
                android:layout_gravity="end"
                android:layout_marginTop="6dp"
                android:layout_marginBottom="6dp"
                android:layout_marginEnd="2dp" />

            <TextView
                android:id="@+id/tvLetterHint"
                android:layout_width="82dp"
                android:layout_height="82dp"
                android:layout_gravity="center"
                android:background="@drawable/bg_pill_distance"
                android:gravity="center"
                android:textColor="@color/ssf_text_primary"
                android:textSize="34sp"
                android:textStyle="bold"
                android:visibility="gone" />

            <!-- Empty: more product-like -->
            <LinearLayout
                android:id="@+id/emptyView"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="22dp"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/empty"
                    android:textColor="@color/ssf_text_primary"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="Try a different keyword or filter."
                    android:textColor="@color/ssf_text_secondary"
                    android:textSize="13sp" />
            </LinearLayout>

            <!-- Error -->
            <LinearLayout
                android:id="@+id/errorView"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="22dp"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/load_error"
                    android:textColor="@color/ssf_text_primary"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <Button
                    android:id="@+id/btnRetry"
                    style="@style/Widget.SSF.Button.Secondary"
                    android:layout_width="wrap_content"
                    android:layout_height="48dp"
                    android:layout_marginTop="12dp"
                    android:text="@string/retry" />
            </LinearLayout>

            <com.google.android.material.floatingactionbutton.FloatingActionButton
                android:id="@+id/fabBackToTop"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom|end"
                android:layout_marginEnd="34dp"
                android:layout_marginBottom="12dp"
                android:contentDescription="@string/back_to_top"
                android:visibility="gone"
                android:alpha="0"
                android:scaleX="0.85"
                android:scaleY="0.85"
                app:backgroundTint="@color/ssf_primary_variant"
                app:fabSize="mini"
                app:srcCompat="@drawable/ic_arrow_up_16"
                app:tint="@color/white" />
        </FrameLayout>
    </LinearLayout>

    </LinearLayout>

    <include layout="@layout/drawer_nav_panel" />
</androidx.drawerlayout.widget.DrawerLayout>
