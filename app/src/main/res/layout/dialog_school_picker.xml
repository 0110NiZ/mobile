<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="460dp"
    android:background="@drawable/bg_compare_picker_surface"
    android:paddingTop="6dp"
    android:paddingBottom="6dp">

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerSchoolPicker"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingEnd="24dp" />

    <com.example.smartschoolfinder.widget.CompareSideBar
        android:id="@+id/sideBarSchoolPicker"
        android:layout_width="22dp"
        android:layout_height="match_parent"
        android:layout_gravity="end|center_vertical"
        android:layout_marginEnd="2dp" />

    <TextView
        android:id="@+id/tvLetterHintSchoolPicker"
        android:layout_width="82dp"
        android:layout_height="82dp"
        android:layout_gravity="center"
        android:background="@drawable/bg_pill_distance"
        android:gravity="center"
        android:textColor="@color/ssf_text_primary"
        android:textSize="34sp"
        android:textStyle="bold"
        android:visibility="gone" />
</FrameLayout>
