<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.SmartSchoolFinder" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/ssf_primary</item>
        <item name="colorPrimaryVariant">@color/ssf_primary_variant</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorPrimaryContainer">@color/ssf_primary_container</item>
        <item name="colorOnPrimaryContainer">@color/white</item>
        <item name="colorSecondary">@color/ssf_secondary</item>
        <item name="colorSecondaryVariant">@color/ssf_secondary</item>
        <item name="colorOnSecondary">@color/ssf_text_primary</item>
        <item name="colorSecondaryContainer">@color/ssf_secondary_container</item>
        <item name="colorOnSecondaryContainer">@color/ssf_text_primary</item>

        <item name="colorSurface">@color/ssf_surface</item>
        <item name="colorOnSurface">@color/ssf_text_primary</item>
        <item name="android:colorBackground">@color/ssf_bg</item>
        <item name="android:windowBackground">@color/ssf_bg</item>

        <item name="android:statusBarColor" tools:targetApi="l">@color/ssf_primary_variant</item>
        <item name="android:navigationBarColor" tools:targetApi="l">@color/ssf_bg</item>
        <item name="android:windowAnimationStyle">@style/Animation.SSF.Window</item>

        <item name="android:textColorPrimary">@color/ssf_text_primary</item>
        <item name="android:textColorSecondary">@color/ssf_text_secondary</item>
        <item name="colorControlActivated">@color/ssf_primary_variant</item>

        <item name="materialButtonStyle">@style/Widget.SSF.Button.Gradient</item>
        <item name="textInputStyle">@style/Widget.SSF.TextInputLayout</item>
        <item name="android:editTextStyle">@style/Widget.SSF.EditText</item>
        <item name="android:spinnerStyle">@style/Widget.SSF.Spinner</item>
        <item name="materialAlertDialogTheme">@style/ThemeOverlay.SSF.MaterialAlertDialog</item>
    </style>

    <style name="Theme.SmartSchoolFinder.Splash" parent="Theme.SmartSchoolFinder">
        <item name="android:windowBackground">@color/ic_launcher_background</item>
        <item name="android:windowDisablePreview">true</item>
        <item name="android:statusBarColor" tools:targetApi="l">@color/ic_launcher_background</item>
        <item name="android:navigationBarColor" tools:targetApi="l">@color/ic_launcher_background</item>
    </style>

    <style name="ThemeOverlay.SSF.MaterialAlertDialog" parent="ThemeOverlay.MaterialComponents.MaterialAlertDialog">
        <item name="backgroundTint">?attr/colorSecondaryContainer</item>
        <item name="android:textColorPrimary">?attr/colorOnSurface</item>
        <item name="android:textColorSecondary">?attr/colorOnSurface</item>
        <item name="buttonBarPositiveButtonStyle">@style/Widget.SSF.Button.DialogAction</item>
        <item name="buttonBarNegativeButtonStyle">@style/Widget.SSF.Button.DialogAction</item>
        <item name="buttonBarNeutralButtonStyle">@style/Widget.SSF.Button.DialogAction</item>
    </style>
</resources>
