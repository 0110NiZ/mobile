<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_enabled="false">
        <shape android:shape="rectangle">
            <solid android:color="@color/ssf_button_disabled" />
            <corners android:radius="20dp" />
        </shape>
    </item>
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <gradient
                android:angle="0"
                android:startColor="@color/ssf_primary_pressed"
                android:endColor="@color/ssf_secondary_pressed" />
            <corners android:radius="20dp" />
        </shape>
    </item>
    <item android:drawable="@drawable/bg_gradient_button" />
</selector>

