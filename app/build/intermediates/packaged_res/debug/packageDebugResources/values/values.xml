    <style name="Animation.SSF.Window" parent="@android:style/Animation.Activity">
        <item name="android:activityOpenEnterAnimation">@anim/ssf_fade_in</item>
        <item name="android:activityOpenExitAnimation">@anim/ssf_fade_out</item>
        <item name="android:activityCloseEnterAnimation">@anim/ssf_fade_in</item>
        <item name="android:activityCloseExitAnimation">@anim/ssf_fade_out</item>
    </style>
    <style name="TextAppearance.SSF.Caption" parent="TextAppearance.MaterialComponents.Caption">
        <item name="android:textColor">@color/ssf_text_secondary</item>
    </style>
    <style name="TextAppearance.SSF.Subtitle" parent="TextAppearance.MaterialComponents.Body2">
        <item name="android:textColor">@color/ssf_text_secondary</item>
    </style>
    <style name="TextAppearance.SSF.Title" parent="TextAppearance.MaterialComponents.Headline6">
        <item name="android:textColor">@color/ssf_text_primary</item>
        <item name="android:textStyle">bold</item>
    </style>
    <style name="Theme.SmartSchoolFinder" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/ssf_primary</item>
        <item name="colorPrimaryVariant">@color/ssf_primary_variant</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/ssf_secondary</item>
        <item name="colorSecondaryVariant">@color/ssf_secondary</item>
        <item name="colorOnSecondary">@color/ssf_text_primary</item>

        <item name="colorSurface">@color/ssf_surface</item>
        
        <item name="android:colorBackground">@color/ssf_bg</item>
        <item name="android:windowBackground">@color/ssf_bg</item>

        <item name="android:statusBarColor" ns1:targetApi="l">@color/ssf_primary_variant</item>
        <item name="android:navigationBarColor" ns1:targetApi="l">@color/ssf_bg</item>
        <item name="android:windowAnimationStyle">@style/Animation.SSF.Window</item>

        
        <item name="android:textColorPrimary">@color/ssf_text_primary</item>
        <item name="android:textColorSecondary">@color/ssf_text_secondary</item>
        <item name="colorControlActivated">@color/ssf_primary_variant</item>

        
        <item name="materialButtonStyle">@style/Widget.SSF.Button.Gradient</item>

        
        <item name="textInputStyle">@style/Widget.SSF.TextInputLayout</item>
        <item name="android:editTextStyle">@style/Widget.SSF.EditText</item>

        
        <item name="android:spinnerStyle">@style/Widget.SSF.Spinner</item>
    </style>
    <style name="Widget.SSF.Button.Gradient" parent="Widget.MaterialComponents.Button">
        <item name="android:background">@drawable/ripple_gradient_button</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textColorHint">@color/white</item>
        <item name="android:textStyle">bold</item>
        <item name="cornerRadius">20dp</item>
        <item name="android:minHeight">48dp</item>
        <item name="android:insetLeft">0dp</item>
        <item name="android:insetRight">0dp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="android:elevation">6dp</item>
        <item name="iconPadding">8dp</item>
        <item name="android:stateListAnimator">@animator/ssf_button_state_list_animator</item>
    </style>
    <style name="Widget.SSF.Button.Gradient.Small" parent="Widget.SSF.Button.Gradient">
        <item name="android:minHeight">44dp</item>
        <item name="android:textSize">13sp</item>
        <item name="android:paddingLeft">12dp</item>
        <item name="android:paddingRight">12dp</item>
    </style>
    <style name="Widget.SSF.Button.Secondary" parent="Widget.MaterialComponents.Button">
        <item name="android:background">@drawable/ripple_outline_button</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textStyle">bold</item>
        <item name="cornerRadius">20dp</item>
        <item name="android:minHeight">48dp</item>
        <item name="android:insetLeft">0dp</item>
        <item name="android:insetRight">0dp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="android:elevation">2dp</item>
        <item name="android:stateListAnimator">@animator/ssf_button_state_list_animator</item>
    </style>
    <style name="Widget.SSF.Button.Subtle" parent="Widget.MaterialComponents.Button">
        <item name="android:background">@drawable/ripple_subtle_button</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textStyle">bold</item>
        <item name="cornerRadius">20dp</item>
        <item name="android:minHeight">44dp</item>
        <item name="android:insetLeft">0dp</item>
        <item name="android:insetRight">0dp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="android:elevation">0dp</item>
        <item name="android:stateListAnimator">@animator/ssf_button_state_list_animator</item>
    </style>
    <style name="Widget.SSF.Card" parent="Widget.MaterialComponents.CardView">
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">6dp</item>
        <item name="strokeColor">@color/ssf_stroke</item>
        <item name="strokeWidth">1dp</item>
        <item name="android:backgroundTint">@color/ssf_surface</item>
        <item name="android:stateListAnimator">@animator/ssf_card_state_list_animator</item>
    </style>
    <style name="Widget.SSF.EditText" parent="Widget.MaterialComponents.TextInputEditText.OutlinedBox">
        <item name="android:textColor">@color/ssf_text_primary</item>
        <item name="android:textColorHint">@color/ssf_text_hint</item>
        <item name="android:padding">14dp</item>
    </style>
    <style name="Widget.SSF.EditText.Plain" parent="Widget.AppCompat.EditText">
        <item name="android:background">@drawable/bg_text_field</item>
        <item name="android:textColor">@color/ssf_text_primary</item>
        <item name="android:textColorHint">@color/ssf_text_hint</item>
        <item name="android:padding">14dp</item>
    </style>
    <style name="Widget.SSF.Spinner" parent="Widget.AppCompat.Spinner.Underlined">
        <item name="android:background">@drawable/bg_spinner_rounded</item>
        <item name="android:paddingLeft">14dp</item>
        <item name="android:paddingRight">14dp</item>
        <item name="android:minHeight">48dp</item>
    </style>
    <style name="Widget.SSF.TextInputLayout" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxBackgroundColor">@color/ssf_surface</item>
        <item name="boxStrokeColor">@color/ssf_primary_variant</item>
        <item name="hintTextColor">@color/ssf_text_hint</item>
        <item name="android:paddingTop">2dp</item>
        <item name="android:paddingBottom">2dp</item>
        <item name="boxCornerRadiusTopStart">16dp</item>
        <item name="boxCornerRadiusTopEnd">16dp</item>
        <item name="boxCornerRadiusBottomStart">16dp</item>
        <item name="boxCornerRadiusBottomEnd">16dp</item>
        <item name="boxStrokeWidth">1dp</item>
        <item name="boxStrokeWidthFocused">2dp</item>
    </style>
</resources>